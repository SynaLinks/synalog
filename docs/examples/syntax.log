WITH t_0_Orders AS (SELECT * FROM (
  
    SELECT
      10 AS order_id,
      1 AS customer_id,
      1500 AS amount
   UNION ALL
  
    SELECT
      11 AS order_id,
      2 AS customer_id,
      240 AS amount
   UNION ALL
  
