# Environment variables for connecting `synalog` to remote SQL engines.
#
# Copy this file to `.env` and fill in the connection string(s) you need.
# `.env` is git-ignored so your credentials stay out of version control.
#
# synalog loads `.env` automatically from the program file's directory and the
# current directory, so just running from the project root is enough:
#
#   synalog program.l run MyPredicate --engine psql
#
# Real environment variables (e.g. an `export` in your shell) take precedence
# over what's written here. Local engines — duckdb (the default) and sqlite —
# need none of this; they build their connection from --load files. Only the
# network engines below use a connection string.
#
# Resolution order for a connection string is: the --dsn flag, then the
# SYNALOG_<ENGINE>_DSN variable here, then a connection saved with
# `synalog connect <engine> <dsn>`. Setting a variable here is equivalent to
# saving it, without writing it to the config file.

# PostgreSQL
# SYNALOG_PSQL_DSN=postgresql://user:password@host:5432/database

# Trino  (add :password for Basic auth over https; /catalog/schema sets defaults)
# SYNALOG_TRINO_DSN=trino://user@host:8080/catalog/schema

# Presto
# SYNALOG_PRESTO_DSN=presto://user@host:8080/catalog/schema

# Databricks  (the password/userinfo is your access token)
# SYNALOG_DATABRICKS_DSN=databricks://<access-token>@<host>?http_path=/sql/1.0/warehouses/<warehouse-id>

# BigQuery  (auth is via Application Default Credentials; the DSN only names the
# billing project, and optionally a location). May be a bare project id.
# SYNALOG_BIGQUERY_DSN=bigquery://my-gcp-project?location=US

# Optional: where `synalog connect` stores saved connections
# (default: ~/.config/synalog). Override to keep them inside the project.
# SYNALOG_CONFIG_DIR=.synalog
